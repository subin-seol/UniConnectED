+class ParticipantUpdateTestCase(OpportunityParticipantV2APITestCase):
+    """Test cases for updating participant details"""
+
+    def test_update_questionnaire_answers(self):
+        """Test updating participant questionnaire answers"""
+        # Create participant
+        participant = OpportunityParticipant.objects.create(
+            opportunity=self.public_opportunity,
+            email=self.user.email,
+            user=self.user,
+            user_type=self.student_type,
+            accepted=True,
+            questionnaire_answers={'skill': 'Python'}
+        )
+
+        self.client.credentials(HTTP_AUTHORIZATION=f'Token {self.token.key}')
+
+        url = reverse('opportunity-participant-id',
+                      kwargs={
+                          'opportunity_id': self.public_opportunity.id,
+                          'participant_id': participant.id
+                      })
+        data = {
+            'questionnaire_answers': {'skill': 'Django', 'experience': '2 years'}
+        }
+
+        response = self.client.patch(url, data, format='json')
+
+        self.assertEqual(response.status_code, status.HTTP_200_OK)
+
+        # Verify update in database
+        participant.refresh_from_db()
+        expected_answers = {'skill': 'Django', 'experience': '2 years'}
+        self.assertEqual(participant.questionnaire_answers, expected_answers)
+
+    def test_update_other_user_participant_returns_403(self):
+        """Test updating another user's participant returns 403"""
+        # Create participant for other user
+        other_participant = OpportunityParticipant.objects.create(
+            opportunity=self.public_opportunity,
+            email=self.other_user.email,
+            user=self.other_user,
+            user_type=self.student_type,
+            accepted=True
+        )
+
+        self.client.credentials(HTTP_AUTHORIZATION=f'Token {self.token.key}')
+
+        url = reverse('opportunity-participant-id',
+                      kwargs={
+                          'opportunity_id': self.public_opportunity.id,
+                          'participant_id': other_participant.id
+                      })
+        data = {
+            'questionnaire_answers': {'skill': 'Hacking'}
+        }
+
+        response = self.client.patch(url, data, format='json')
+
+        self.assertEqual(response.status_code, status.HTTP_403_FORBIDDEN)
+
+
+class ParticipantDeleteTestCase(OpportunityParticipantV2APITestCase):
+    """Test cases for deleting participant"""
+
+    def test_delete_own_participation(self):
+        """Test deleting own participation"""
+        # Create participant
+        participant = OpportunityParticipant.objects.create(
+            opportunity=self.public_opportunity,
+            email=self.user.email,
+            user=self.user,
+            user_type=self.student_type,
+            accepted=True
+        )
+
+        self.client.credentials(HTTP_AUTHORIZATION=f'Token {self.token.key}')
+
+        url = reverse('opportunity-participant-detail',
+                      kwargs={'opportunity_id': self.public_opportunity.id})
+
+        response = self.client.delete(url)
+
+        self.assertEqual(response.status_code, status.HTTP_204_NO_CONTENT)
+
+        # Verify participant was deleted
+        self.assertFalse(
+            OpportunityParticipant.objects.filter(id=participant.id).exists()
+        )
+
+    def test_delete_non_participant_returns_404(self):
+        """Test deleting participation when not a participant returns 404"""
+        self.client.credentials(HTTP_AUTHORIZATION=f'Token {self.token.key}')
+
+        url = reverse('opportunity-participant-detail',
+                      kwargs={'opportunity_id': self.public_opportunity.id})
+
+        response = self.client.delete(url)
+
+        self.assertEqual(response.status_code, status.HTTP_404_NOT_FOUND)
