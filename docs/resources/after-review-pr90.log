+    def get_type(self, obj):
+        """Return the type of participant (organisation or student)"""
+        if obj.organisation_id:
+            return "organisation"
+        elif obj.user_id:
+            return "student"
+        else:
+            return "pending"
+
+    def get_data(self, obj):
+        """Return complete serialized data based on participant type"""
+        opportunity_id = self.context.get('opportunity_id')
+
+        if obj.organisation_id:
+            serializer = OrganisationSerializerComplete(
+                obj.organisation,
+                context={
+                    'opportunity_id': opportunity_id} if opportunity_id else {}
+            )
+            return serializer.data
+
+        elif obj.user_id:
+            # Get the student profile
+            profile = getattr(obj.user, 'studentprofile', None)
+            if profile is None:
+                profile = StudentProfile.objects.filter(user=obj.user).first()
+
+            if profile is None:
+                return {"error": "Student profile not found"}
+
+            serializer = StudentProfileSerializerComplete(
+                profile,
+                context={
+                    'opportunity_id': opportunity_id} if opportunity_id else {}
+            )
+            return serializer.data
+
+        else:
+            # No linked account yet, so return basic participant info
+            return {
+                "email": obj.email,
+                "accepted": obj.accepted,
+                "invited_time": obj.invited_time,
+                "questionnaire_answers": obj.questionnaire_answers
+            }
 
 
